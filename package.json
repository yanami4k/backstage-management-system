{
  "name": "backstage-management-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:pro": "run-p type-check \"build-only --mode production\" --",
    "build:test": "run-p type-check \"build-only --mode test\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "preinstall": "npx only-allow pnpm",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache && oxlint . --fix && stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "lint:check": "eslint . --cache && oxlint . && stylelint \"src/**/*.{vue,css,scss}\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:oxlint:check": "oxlint .",
    "lint:eslint": "eslint . --fix --cache",
    "lint:eslint:check": "eslint . --cache",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "lint:stylelint:check": "stylelint \"src/**/*.{vue,css,scss}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.15.0",
    "element-plus": "^2.13.7",
    "mockjs": "^1.1.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "only-allow": "^1.2.2",
    "oxlint": "~1.57.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.1",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
